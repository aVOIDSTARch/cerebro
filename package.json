{
  "name": "cerebro",
  "version": "1.0.0",
  "description": "Personal knowledge graph with multi-modal epistemic tracking",
  "type": "module",
  "main": "dist/api/server.js",
  "scripts": {
    "bootstrap": "tsx scripts/bootstrap.ts",
    "dev": "tsx watch src/api/server.ts",
    "build": "tsc",
    "start": "node dist/api/server.js",
    "test": "vitest run",
    "test:unit": "vitest run src/",
    "test:watch": "vitest",
    "dedup": "tsx src/quarantine/dedup.ts",
    "import": "tsx scripts/import.ts",
    "export": "tsx scripts/export.ts"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/aVOIDSTARch/cerebro.git"
  },
  "keywords": [
    "knowledge-graph",
    "epistemic",
    "kuzu",
    "typescript"
  ],
  "author": "Louie Casinelli",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/aVOIDSTARch/cerebro/issues"
  },
  "homepage": "https://github.com/aVOIDSTARch/cerebro#readme",
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/static": "^9.0.0",
    "@types/better-sqlite3": "^7.6.13",
    "better-sqlite3": "^12.8.0",
    "chromadb": "^3.4.0",
    "fastify": "^5.8.2",
    "kuzu": "^0.11.3",
    "meilisearch": "^0.56.0",
    "pino-pretty": "^13.1.3",
    "uuid": "^13.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/uuid": "^10.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  }
}
